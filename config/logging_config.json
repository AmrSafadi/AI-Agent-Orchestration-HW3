{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(levelname)s: %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "standard",
      "stream": "ext://sys.stderr"
    }
  },
  "loggers": {
    "bookgen": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    }
  },
  "root": {
    "handlers": ["console"],
    "level": "INFO"
  }
}
