# Copy this file to .env and fill in local secrets. Never commit .env.
# The default dry-run execution path does not call any API.
#
# Guideline 7.4 requires a committed example file with dummy values and that
# real secrets live only in environment variables (never in source code).

# Required only for real CrewAI execution (`python -m bookgen.main --run-crew`).
OPENAI_API_KEY=

# Model provider selection and default model.
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
